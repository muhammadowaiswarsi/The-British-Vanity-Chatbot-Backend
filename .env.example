# Server
PORT=5001
NODE_ENV=production

# MongoDB (same database as the e-commerce backend)
MONGO_URI=
MONGODB_URI=

# OpenRouter (chat + vision) — REQUIRED on Vercel
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free

# OpenAI (optional — used for embeddings if set instead of OpenRouter)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Main e-commerce backend (policy/FAQ source APIs)
MAIN_BACKEND_URL=https://tbv-api.incitertech.com
ECOMMERCE_API_URL=https://tbv-api.incitertech.com/api

# Qdrant — REQUIRED for product/policy RAG
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=products
QDRANT_POLICIES_COLLECTION=policies
QDRANT_FAQS_COLLECTION=faqs

# CORS — comma-separated extra origins allowed (optional)
FRONTEND_URL=https://the-british-vanity.incitertech.com
ALLOWED_ORIGINS=http://localhost:3000,https://the-british-vanity.incitertech.com
