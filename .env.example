# Server
PORT=5001
NODE_ENV=development

# MongoDB (same database as the e-commerce backend)
MONGODB_URI=mongodb://localhost:27017/the-british-vanity

# OpenAI (embeddings + optional chat)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter (chat + vision)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free

# Main e-commerce backend (policy/FAQ source APIs)
MAIN_BACKEND_URL=http://localhost:5000

# Legacy alias — used as fallback if MAIN_BACKEND_URL is unset
ECOMMERCE_API_URL=http://localhost:5000/api

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products
QDRANT_POLICIES_COLLECTION=policies
QDRANT_FAQS_COLLECTION=faqs

# CORS
FRONTEND_URL=http://localhost:3000
